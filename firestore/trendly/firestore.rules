rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /{path=**}/applications/{applicationId} {
      allow read: if isAuthenticated();
    }
    match /{path=**}/invitations/{invitationId} {
      allow read: if isAuthenticated();
    }
    match /{path=**}/members/{memberId} {
      allow read: if isAuthenticated();
    }
    match /{path=**}/orgMembers/{memberId} {
      allow read: if isAuthenticated();
    }

    match /scrapped-socials/{socialId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }
    // Reverse index: platformAccountId -> connected brand/user + social.
    // Written/read server-side only (inbox webhook routing). Admin SDK bypasses.
    match /socialAccountIndex/{platformAccountId} {
      allow read, write: if false;
    }
    match /agency-hires/{hireId} {
      allow read, write: if isAuthenticated();
    }

    // ── Public share links ────────────────────────────────────────────────
    // Maps an unguessable token → a shared Strategy / Calendar month / Content.
    // Anyone (anonymous included) may resolve an ENABLED link; disabling it
    // (enabled=false) revokes public access. Only content managers of the
    // owning brand may create/toggle a link.
    match /shareLinks/{token} {
      allow read:   if resource.data.enabled == true;
      allow create: if isAuthenticated() &&
                       (canManageContent(request.resource.data.brandId) ||
                        canManageContentStrategy(request.resource.data.brandId));
      allow update, delete: if isAuthenticated() &&
                       (canManageContent(resource.data.brandId) ||
                        canManageContentStrategy(resource.data.brandId));
    }

    match /collaborations-invites/{collabUserId} {
      allow read, write: if isAuthenticated() && isAdmin();
    }
    match /connections/{userId} {
      allow read: if isAuthenticated();
      // allow write: if isAuthenticated();
    }
    match /userImages/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Stores data about influencers and creators
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId && !doesManagerExists(userId);
      allow update, delete: if isAuthenticated() && request.auth.uid == userId && validateUserUpdate();

      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if isAuthenticated();
      }
      match /socials/{socialId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }
      match /invitations/{inviteUserId} {
        allow read: if isAuthenticated();
        allow update: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Stores all brand managers
    match /managers/{managerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == managerId && !doesUserExists(managerId);
      allow update, delete: if isAuthenticated() && request.auth.uid == managerId;

      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && request.auth.uid == managerId;
        allow write: if isAuthenticated();
      }
    }

    // Stores all brands
    match /brands/{brandId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();

      match /socials/{socialId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
      match /socialAccounts/{accountId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
      // Access tokens are sensitive — server-only (Admin SDK bypasses rules).
      // Never readable/writable by clients.
      match /socialTokens/{accountId} {
        allow read, write: if false;
      }

      // Analytics cache + daily snapshots. Written/read server-side only —
      // the dashboard reads analytics through the backend API, never directly.
      // Admin SDK bypasses these rules.
      match /analyticsCache/{cacheId} {
        allow read, write: if false;
      }
      match /analyticsSnapshots/{snapshotId} {
        allow read, write: if false;
      }

      // Inbox conversations (DMs + comments). Read: any brand member. Writes go
      // through the backend (Admin SDK), so clients never write directly.
      match /inbox/{conversationId} {
        allow read:  if isAuthenticated() && isBrandMember(brandId);
        allow write: if false;
      }

      // ── Strategies ───────────────────────────────────────────────────────
      // Read: any brand member. Mutate: content-strategy capability holders
      // (owner / admin / content_manager).
      match /strategies/{strategyId} {
        // Read: any brand member, OR anyone when the doc is publicly shared.
        allow read:                   if (isAuthenticated() && isBrandMember(brandId))
                                         || isResourcePublic();
        allow create, update, delete: if isAuthenticated() && canManageContentStrategy(brandId);

        // Strategy document-level and snippet comments.
        // Brand members always read/write. On a publicly-shared strategy a
        // logged-in NON-anonymous guest may also read and post (Tier 2) — but
        // anonymous (logged-out) viewers cannot.
        match /comments/{commentId} {
          allow read:   if (isAuthenticated() && isBrandMember(brandId))
                           || (isNonAnonAuthed() && strategyShared(brandId, strategyId));
          allow create: if ((isAuthenticated() && isBrandMember(brandId))
                           || (isNonAnonAuthed() && strategyShared(brandId, strategyId)))
                           && request.resource.data.authorId == request.auth.uid;
          // Only the comment author can edit or delete their own comment
          allow update, delete: if isAuthenticated() && isCommentAuthor() &&
                           (isBrandMember(brandId) || strategyShared(brandId, strategyId));
        }

        // Presence heartbeats — each manager can only write their own doc.
        // Also carries Yjs awareness state (cursor/selection) for live co-editing.
        match /presence/{managerId} {
          allow read:  if isAuthenticated() && isBrandMember(brandId);
          allow write: if isAuthenticated() && isBrandMember(brandId)
                         && request.auth.uid == managerId;
        }

        // Yjs CRDT update log (real-time collaboration, Phase 2).
        // Append-only base64 deltas + periodic compaction snapshots. Any brand
        // member may read (to sync); content-strategy capability holders may
        // append. Delete is allowed for the same holders so compaction can
        // prune superseded deltas after writing a snapshot.
        match /yupdates/{updateId} {
          allow read:   if isAuthenticated() && isBrandMember(brandId);
          allow create: if isAuthenticated() && canManageContentStrategy(brandId);
          allow delete: if isAuthenticated() && canManageContentStrategy(brandId);
        }
      }

      // ── Contents ─────────────────────────────────────────────────────────
      // Read: any brand member. Create/update: manage_content holders
      // (incl. content_creator). Delete: content managers/admins/owners only.
      match /contents/{contentId} {
        // Read: any brand member, OR anyone when the doc is publicly shared.
        allow read:           if (isAuthenticated() && isBrandMember(brandId))
                                 || isResourcePublic();
        allow create, update: if isAuthenticated() && canManageContent(brandId);
        allow delete:         if isAuthenticated() && canDeleteContent(brandId);

        // Content comments — shared between Calendar and Content detail page.
        // On a publicly-shared content a logged-in NON-anonymous guest may also
        // read and post (Tier 2); anonymous viewers cannot.
        match /comments/{commentId} {
          allow read:   if (isAuthenticated() && isBrandMember(brandId))
                           || (isNonAnonAuthed() && contentShared(brandId, contentId));
          allow create: if ((isAuthenticated() && isBrandMember(brandId))
                           || (isNonAnonAuthed() && contentShared(brandId, contentId)))
                           && request.resource.data.authorId == request.auth.uid;
          allow update, delete: if isAuthenticated() && isCommentAuthor() &&
                           (isBrandMember(brandId) || contentShared(brandId, contentId));
        }
      }

      // ── Calendar month public share toggle ───────────────────────────────
      // Stored at brands/{brandId}/calendarShares/{YYYY-MM}. Tracks whether a
      // month is publicly shared + the token. The month's content items are
      // served to public viewers by the backend (Admin SDK), so this doc only
      // gates the toggle state — readable by anyone when enabled.
      match /calendarShares/{month} {
        allow read:   if (isAuthenticated() && isBrandMember(brandId))
                         || (resource != null && resource.data.enabled == true);
        allow write:  if isAuthenticated() && canManageContent(brandId);
      }

      // ── Calendar month-level comments ────────────────────────────────────
      // Stored at brands/{brandId}/calendarComments/{YYYY-MM}/comments/{commentId}
      match /calendarComments/{month}/comments/{commentId} {
        allow read:   if isAuthenticated() && isBrandMember(brandId);
        allow create: if isAuthenticated() && isBrandMember(brandId);
        allow update, delete: if isAuthenticated() && isBrandMember(brandId) && isCommentAuthor();
      }

      match /members/{managerId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }

      // ── Teams ────────────────────────────────────────────────────────────
      // Access units within a brand: each team holds a feature→privileges map
      // its members inherit. Any brand member may read; only members whose team
      // grants brand_admin:teams may mutate.
      match /teams/{teamId} {
        allow read:  if isAuthenticated() && isBrandMember(brandId);
        allow write: if isAuthenticated() && canManageBrandTeams(brandId);
      }

      match /notifications/{notificationId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // Stores organizations — the top-level tenant above brands. Billing /
    // subscription lives here; each brand references its org via organizationId.
    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();

      // Org membership + role. Named "orgMembers" (NOT "members") on purpose so
      // it does not collide with the brands/{brandId}/members collection-group
      // queries used by the brand switcher.
      match /orgMembers/{managerId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // Stores all collaborations
    match /collaborations/{collaborationId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();

      match /applications/{applicationId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
      match /invitations/{invitationId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // // Stores groups created for collaborations
    // match /groups/{groupId} {
    //   allow read: if isAuthenticated();
    //   allow write: if isAuthenticated();
    //   match /messages/{messageId} {
    //     allow read: if isAuthenticated();
    //     allow write: if isAuthenticated();
    //   }
    // }

    // Stores contracts created for collaborations
    match /contracts/{contractId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();

      // // match /deliverables/{deliverableId} {
      // //   allow read, write: if isAuthenticated();
      // // }
      // // match /payments/{paymentId} {
      // //   allow read, write: if isAuthenticated();
      // // }
    }

    // ── Helper functions ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // True for Firebase anonymous sessions (used by logged-out public viewers).
    function isAnonymous() {
      return isAuthenticated() &&
        request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // True for a real (non-anonymous) logged-in user — i.e. an actual manager
    // account, which may or may not be a member of the shared brand.
    function isNonAnonAuthed() {
      return isAuthenticated() && !isAnonymous();
    }

    // True when the document being read carries an enabled public-share flag.
    // Used on the resource's own read rule (cheap field check, no extra read).
    function isResourcePublic() {
      return resource != null &&
        resource.data.get('publicShare', {}).get('enabled', false) == true;
    }

    // True when the given strategy is publicly shared (cross-doc lookup — used
    // only by the comments sub-rules, not the hot document read path).
    function strategyShared(brandId, strategyId) {
      return get(/databases/$(database)/documents/brands/$(brandId)/strategies/$(strategyId))
        .data.get('publicShare', {}).get('enabled', false) == true;
    }

    // True when the given content item is publicly shared.
    function contentShared(brandId, contentId) {
      return get(/databases/$(database)/documents/brands/$(brandId)/contents/$(contentId))
        .data.get('publicShare', {}).get('enabled', false) == true;
    }

    function isAdmin() {
      return true;
    }

    function doesManagerExists(uid) {
      return exists(/databases/$(database)/documents/managers/$(uid));
    }

    function doesUserExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    /**
     * Returns true if the calling user is a registered member of the given brand.
     * Checks for the manager doc under brands/{brandId}/members/{uid}.
     */
    function isBrandMember(brandId) {
      return exists(
        /databases/$(database)/documents/brands/$(brandId)/members/$(request.auth.uid)
      );
    }

    /**
     * The calling user's member doc data within the given brand.
     */
    function brandMemberData(brandId) {
      return get(
        /databases/$(database)/documents/brands/$(brandId)/members/$(request.auth.uid)
      ).data;
    }

    /**
     * True while the member has no team assigned (pre-migration legacy member).
     * Such members are allowed through until scripts/migrate-teams-v2 runs —
     * mirrors the backend's transition shim. Remove once migration completes.
     */
    function isLegacyBrandMember(brandId) {
      return !('teamId' in brandMemberData(brandId))
        || brandMemberData(brandId).teamId == null
        || brandMemberData(brandId).teamId == '';
    }

    /**
     * The privileges map (feature -> [privilege]) of the team the caller belongs
     * to. Only call when the member has a team (guard with isLegacyBrandMember).
     */
    function callerTeamPrivileges(brandId) {
      return get(
        /databases/$(database)/documents/brands/$(brandId)/teams/$(brandMemberData(brandId).teamId)
      ).data.privileges;
    }

    /**
     * Returns true if the caller's team grants `priv` under `feature`. Legacy
     * members (no team) are allowed through during the migration window.
     * Relies on Firestore rules' short-circuit evaluation so the team get() is
     * skipped for legacy members.
     */
    function hasFeaturePrivilege(brandId, feature, priv) {
      return isBrandMember(brandId) && (
        isLegacyBrandMember(brandId) || (
          feature in callerTeamPrivileges(brandId) &&
          priv in callerTeamPrivileges(brandId)[feature]
        )
      );
    }

    // Team administration: brand_admin:teams.
    function canManageBrandTeams(brandId) {
      return hasFeaturePrivilege(brandId, 'brand_admin', 'teams');
    }

    // Content-strategy mutations: strategy admin (create + edit) or editor.
    function canManageContentStrategy(brandId) {
      return hasFeaturePrivilege(brandId, 'strategy', 'admin')
        || hasFeaturePrivilege(brandId, 'strategy', 'editor');
    }

    // Content create/update: content create_edit or editor.
    function canManageContent(brandId) {
      return hasFeaturePrivilege(brandId, 'content', 'create_edit')
        || hasFeaturePrivilege(brandId, 'content', 'editor');
    }

    // Content delete: content create_edit (editors/viewers cannot delete).
    function canDeleteContent(brandId) {
      return hasFeaturePrivilege(brandId, 'content', 'create_edit');
    }

    /**
     * Returns true if the calling user authored the comment being updated/deleted.
     * Used to enforce that managers can only edit or delete their own comments.
     */
    function isCommentAuthor() {
      return request.auth.uid == resource.data.authorId;
    }

    function validateUserUpdate() {
      return (
        request.resource.data.isChatConnected == resource.data.isChatConnected ||
        !(resource.data.keys().hasAll(['isChatConnected']))
      );
    }
  }
}
